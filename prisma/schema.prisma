generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  senha               String
  nome                String
  role                Role              @default(COMUM)
  cpf                 String?           @unique
  telefone            String?
  plano               String?           @default("GRATUITO")
  planoCiclo          String            @default("MENSAL")
  planoStatus         String            @default("active")
  planoExpiresAt      DateTime?
  cargo               String?
  avatarUrl           String?
  resetToken          String?           @unique
  resetExpires        DateTime?
  darkMode            Boolean           @default(false)
  idioma              String            @default("pt-BR")
  notificacoesEmail   Boolean           @default(true)
  ipOrigem            String?
  lastLoginAt         DateTime?
  empresaId           String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tempEmail           String?
  verificationCode    String?
  verificationExpires DateTime?
  limiteEmpresas      Int               @default(5)
  tutorialStep        Int               @default(0)
  creditosPlano       Int               @default(0)
  creditosExtras      Int               @default(0)
  dataRenovacaoCiclo  DateTime?
  empresasContabeis   ContadorVinculo[] @relation("ContadorUser")
  pedidos             Pedido[]
  historicoPlanos     PlanHistory[]
  ticketsAtendidos    Ticket[]          @relation("AtendenteTicket")
  ticketsCriados      Ticket[]          @relation("SolicitanteTicket")
  mensagensTicket     TicketMensagem[]
  empresa             Empresa?          @relation("DonoEmpresa", fields: [empresaId], references: [id])
  clientes            UserCliente[]
  empresasAdicionais  Int       @default(0) 
  empresasFaturadas   Empresa[] @relation("FaturamentoEmpresa") 
  eventosCrm          UserEvent[] 
  faturas         Fatura[]
  cuponsUsados    CupomLog[]
}

model Empresa {
  id                       String            @id @default(uuid())
  documento                String            @unique
  ambiente                 String            @default("PRODUCAO")
  cadastroCompleto         Boolean           @default(false)
  serieDPS                 String            @default("900")
  ultimoDPS                Int               @default(0)
  email                    String?
  razaoSocial              String
  nomeFantasia             String?
  cep                      String?
  logradouro               String?
  numero                   String?
  complemento              String?
  bairro                   String?
  cidade                   String?
  uf                       String?
  codigoIbge               String?
  aliquotaPadrao           Decimal?          @default(0.00) @db.Decimal(5, 2)
  issRetidoPadrao          Boolean           @default(false)
  tipoTributacaoPadrao     String?           @default("1")
  regimeEspecialTributacao String?           @default("0")
  inscricaoMunicipal       String?
  regimeTributario         String?           @default("MEI")
  certificadoA1            String?
  senhaCertificado         String?
  certificadoVencimento    DateTime?
  updatedAt                DateTime          @updatedAt
  lastApiCheck             DateTime?
  arquivadoEm              DateTime?
  arquivadoPor             String?
  motivoArquivamento       String?
  atividades               Cnae[]
  contadoresLink           ContadorVinculo[] @relation("EmpresaContabil")
  notasEmitidas            NotaFiscal[]      @relation("PrestadorNota")
  logs                     SystemLog[]
  donoUser                 User?             @relation("DonoEmpresa")
  vinculadoA               UserCliente[]
  vendasRealizadas         Venda[]           @relation("VendaPrestador")
  minhaCarteira            VinculoCarteira[]
  donoFaturamentoId String?
  donoFaturamento   User?   @relation("FaturamentoEmpresa", fields: [donoFaturamentoId], references: [id])
}

model Cliente {
  id                 String            @id @default(uuid())
  tipo               String            @default("PJ")
  documento          String?           @unique
  nome               String
  nomeFantasia       String?
  email              String?
  telefone           String?
  inscricaoMunicipal String?
  inscricaoEstadual  String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?
  pais               String            @default("Brasil")
  codigoIbge         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  arquivadoEm        DateTime?
  arquivadoPor       String?
  motivoArquivamento String?
  moeda              String?           @default("BRL")
  nif                String?
  notas              NotaFiscal[]
  vendas             Venda[]
  vinculos           VinculoCarteira[]
}

model VinculoCarteira {
  id              String   @id @default(uuid())
  empresaId       String
  clienteId       String
  apelido         String?
  tags            String?
  observacoes     String?
  emailFinanceiro String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  arquivadoEm     DateTime?
  arquivadoPor    String?
  motivoArquivamento String?
  cliente         Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, clienteId])
}

model Venda {
  id        String       @id @default(uuid())
  empresaId String
  clienteId String
  valor     Decimal      @db.Decimal(10, 2)
  descricao String
  status    String       @default("PENDENTE")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  arquivadoEm DateTime?
  arquivadoPor String?
  motivoArquivamento String?
  notas     NotaFiscal[]
  logs      SystemLog[]
  cliente   Cliente      @relation(fields: [clienteId], references: [id])
  empresa   Empresa      @relation("VendaPrestador", fields: [empresaId], references: [id])
}

model UserCliente {
  id        String   @id @default(uuid())
  userId    String
  empresaId String
  apelido   String?
  createdAt DateTime @default(now())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, empresaId])
}

model Cnae {
  id              String  @id @default(uuid())
  codigo          String
  descricao       String
  principal       Boolean @default(false)
  codigoNbs       String?
  temRetencaoInss Boolean @default(false)
  empresaId       String
  empresa         Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model NotaFiscal {
  id            String     @id @default(uuid())
  vendaId       String?
  numero        Int?
  valor         Decimal    @db.Decimal(10, 2)
  descricao     String
  prestadorCnpj String
  tomadorCnpj   String
  status        StatusNota @default(RASCUNHO)
  xmlBase64     String?
  xmlAutorizadoBase64 String?
  xmlCancelamentoEventoBase64 String?
  pdfBase64     String?
  chaveAcesso   String?
  protocolo     String?
  empresaId     String
  clienteId     String
  cnae          String?
  codigoServico String?
  dataEmissao   DateTime?
  createdAt     DateTime   @default(now())
  arquivadoEm   DateTime?
  arquivadoPor  String?
  motivoArquivamento String?
  cliente       Cliente    @relation(fields: [clienteId], references: [id])
  empresa       Empresa    @relation("PrestadorNota", fields: [empresaId], references: [id])
  venda         Venda?     @relation(fields: [vendaId], references: [id])
}

model ConfiguracaoSistema {
  id             String  @id @default("config")
  modeloDpsJson  String?
  versaoApi      String  @default("1.00")
  ambiente       String  @default("PRODUCAO")
  smtpHost       String?
  smtpPort       Int?    @default(587)
  smtpUser       String?
  smtpPass       String?
  smtpSecure     Boolean @default(false)
  emailRemetente String?
}

model GlobalCnae {
  id                       String   @id @default(uuid())
  codigo                   String   @unique
  descricao                String
  itemLc                   String?
  codigoTributacaoNacional String?
  aliquotaPadrao           Decimal? @db.Decimal(5, 2)
  codigoNbs                String?
  temRetencaoInss          Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  aliquotaCrsf             Decimal? @db.Decimal(5, 2)
  aliquotaIr               Decimal? @db.Decimal(5, 2)
  retemCrsf                Boolean  @default(false)
  retemIr                  Boolean  @default(false)
}

model TributacaoMunicipal {
  id                        String   @id @default(uuid())
  cnae                      String
  codigoIbge                String
  codigoTributacaoMunicipal String
  descricaoServicoMunicipal String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  aliquotaIss               Decimal? @db.Decimal(5, 2)
  exigeNbs                  Boolean  @default(false)

  @@unique([cnae, codigoIbge, codigoTributacaoMunicipal])
}

model Plan {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  description    String?
  priceMonthly   Decimal       @db.Decimal(10, 2)
  priceYearly    Decimal       @db.Decimal(10, 2)
  features       String
  active         Boolean       @default(true)
  recommended    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  maxNotasMensal Int           @default(0)
  diasTeste      Int           @default(0)
  privado        Boolean       @default(false)
  maxClientes    Int           @default(0)
  tipo           String        @default("PLANO")
  historico      PlanHistory[]
  
  faturas        Fatura[]      // <--- ADICIONE ESTA LINHA AQUI!
}

model PlanHistory {
  id            String    @id @default(uuid())
  userId        String
  planId        String
  dataInicio    DateTime  @default(now())
  dataFim       DateTime?
  status        String    @default("ATIVO")
  notasEmitidas Int       @default(0)
  createdAt     DateTime  @default(now())
  arquivadoEm   DateTime?
  arquivadoPor  String?
  motivoArquivamento String?
  plan          Plan      @relation(fields: [planId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  action    String
  message   String
  details   String?
  empresaId String?
  vendaId   String?
  createdAt DateTime @default(now())
  empresa   Empresa? @relation(fields: [empresaId], references: [id])
  venda     Venda?   @relation(fields: [vendaId], references: [id])
}

model Ticket {
  id            String           @id @default(uuid())
  protocolo     Int              @default(autoincrement())
  assunto       String
  categoria     String?
  prioridade    String           @default("MEDIA")
  descricao     String
  status        String           @default("ABERTO")
  clientUnread  Boolean          @default(false)
  anexoBase64   String?
  anexoNome     String?
  catalogId     String?
  solicitanteId String
  atendenteId   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  arquivadoEm   DateTime?
  arquivadoPor  String?
  motivoArquivamento String?
  atendente     User?            @relation("AtendenteTicket", fields: [atendenteId], references: [id])
  catalogItem   TicketCatalog?   @relation(fields: [catalogId], references: [id])
  solicitante   User             @relation("SolicitanteTicket", fields: [solicitanteId], references: [id])
  mensagens     TicketMensagem[]
}

model TicketMensagem {
  id          String   @id @default(uuid())
  mensagem    String
  anexos      String?
  interno     Boolean  @default(false)
  anexoBase64 String?
  anexoNome   String?
  ticketId    String
  usuarioId   String
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  usuario     User     @relation(fields: [usuarioId], references: [id])
}

model ContadorVinculo {
  id         String   @id @default(uuid())
  status     String   @default("PENDENTE")
  contadorId String
  empresaId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  arquivadoEm DateTime?
  arquivadoPor String?
  motivoArquivamento String?
  contador   User     @relation("ContadorUser", fields: [contadorId], references: [id])
  empresa    Empresa  @relation("EmpresaContabil", fields: [empresaId], references: [id])

  @@unique([contadorId, empresaId])
}

model TicketCatalog {
  id         String   @id @default(uuid())
  titulo     String
  prioridade String   @default("MEDIA")
  instrucoes String?
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tickets    Ticket[]
}

model MunicipioHomologado {
  id        String   @id @default(uuid())
  uf        String
  nome      String
  status    Int      @default(2)
  regime    String   @default("SN")
  createdAt DateTime @default(now())
}

model Pedido {
  id              String   @id @default(uuid())
  userId          String
  planoSlug       String
  ciclo           String
  notasAdicionais Int      @default(0)
  valorPlano      Decimal  @db.Decimal(10, 2)
  valorAdicionais Decimal  @db.Decimal(10, 2)
  valorTotal      Decimal  @db.Decimal(10, 2)
  status          String   @default("PENDENTE")
  formaPagamento  String?
  gatewayId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  arquivadoEm     DateTime?
  arquivadoPor    String?
  motivoArquivamento String?
  user            User     @relation(fields: [userId], references: [id])
}

enum Role {
  MASTER
  ADMIN
  SUPORTE
  SUPORTE_TI
  CONTADOR
  COMUM
}

enum StatusNota {
  RASCUNHO
  PROCESSANDO
  AUTORIZADA
  ERRO
  CANCELADA
}

// === CRM: Linha do Tempo e Logs de Relacionamento ===
model UserEvent {
  id          String   @id @default(uuid())
  userId      String
  tipo        String   // Ex: "SISTEMA", "FINANCEIRO", "MANUAL", "EMAIL_ENVIADO"
  titulo      String   // Ex: "Pagamento Recusado", "Anotação de Venda"
  descricao   String?  // Ex: "O cliente informou que vai pagar amanhã."
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// MÓDULO FINANCEIRO & PAGAMENTOS (PIX INTER)
// ==========================================

model Fatura {
  id              String   @id @default(uuid())
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Opcional: Se a fatura for referente à assinatura de um plano principal
  planoId         String?
  plan            Plan?    @relation(fields: [planoId], references: [id])
  
  descricao       String   // Resumo do que foi comprado (Ex: "Basic (1x) + 5 Notas Extras")
  valorTotal      Decimal  @db.Decimal(10, 2) // Valor final pago (já com descontos)
  
  // Controle Financeiro
  status          String   @default("PENDENTE") // PENDENTE, PAGO, CANCELADO, VENCIDO
  metodo          String   @default("PIX")      
  
  // Retorno do Gateway (Banco Inter / Asaas / Stripe)
  txid            String?  // ID da transação no banco
  qrCodePix       String?  @db.Text 
  
  pagoEm          DateTime? 
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relação 1 para N (Uma fatura pode ter registado o uso de um cupom)
  cupomLogs       CupomLog[]

  @@index([userId])
  @@index([status])
  @@index([txid])
}

// ==========================================
// MOTOR DE CUPONS E PARCERIAS
// ==========================================

model Cupom {
  id              String   @id @default(uuid())
  codigo          String   @unique // Ex: VIMDA_A, BEMVINDO50
  
  // Regras de Desconto
  tipoDesconto    String   // 'PORCENTAGEM' ou 'VALOR_FIXO'
  valorDesconto   Decimal  @db.Decimal(10, 2) // Ex: 50.00 (50%) ou 100.00 (R$ 100)
  
  // Regras de Escassez
  validade        DateTime? // Expira em (Nulo = Nunca expira)
  limiteUsos      Int?      // Quantos podem usar no total (Nulo = Infinito)
  vezesUsado      Int       @default(0) // Contador automático
  
  // Regras de Carrinho (As nossas travas inteligentes)
  aplicarEm       String    @default("CARRINHO_TOTAL") // 'CARRINHO_TOTAL', 'SO_ASSINATURA', 'SO_PACOTES'
  maxCiclos       Int?      // Trava de meses (Ex: Dá desconto só em até 2 meses de plano)
  
  // Gestão de Parceiros (Para você pagar comissões)
  parceiroNome    String?   // Ex: "Escritório Contábil XPTO"
  
  ativo           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relação (Quem usou este cupom)
  logs            CupomLog[]

  @@index([codigo])
  @@index([ativo])

  // Novas regras avançadas
  planosValidos        String?   // Guarda os IDs dos planos selecionados no container
  apenasPrimeiraCompra Boolean   @default(false) // Trava para novos clientes
}

// O "Histórico" de usos (A Ponte entre Fatura, Cliente e Cupom)
// É aqui que tiramos o relatório para pagar os parceiros no fim do mês!
model CupomLog {
  id              String   @id @default(uuid())
  
  cupomId         String
  cupom           Cupom    @relation(fields: [cupomId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  faturaId        String
  fatura          Fatura   @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  
  // Fotografia do momento da compra
  descontoAplicado Decimal @db.Decimal(10, 2) // Quantos R$ o cliente economizou nesta fatura
  
  createdAt       DateTime  @default(now())

  @@index([cupomId])
  @@index([userId])
  @@index([faturaId])
}
